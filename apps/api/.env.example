# ====== Server ======
APP_NAME=xgzh-api
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ====== LLM Provider ======
# 推荐：硅基流动 (SiliconFlow) - 一站式接入 DeepSeek / GLM / Qwen / bge
# 注册: https://siliconflow.cn  (新用户送额度)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 或: DeepSeek 官方
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 或: 智谱 GLM
ZHIPU_API_KEY=

# 主力模型选择 (LiteLLM 格式)
# 硅基流动: openai/deepseek-ai/DeepSeek-V3
# DeepSeek 官方: deepseek/deepseek-chat
# 智谱: zhipu/glm-4-flash
LLM_PRIMARY_MODEL=openai/deepseek-ai/DeepSeek-V3
LLM_FALLBACK_MODEL=openai/THUDM/glm-4-9b-chat

# ====== Data Sources ======
# Tushare Pro Token (可选, AKShare 不需要)
# 注册: https://tushare.pro/register
TUSHARE_TOKEN=

# ====== Redis (可选, 缓存/限流) ======
REDIS_URL=redis://localhost:6379/0

# ====== Postgres ======
DATABASE_URL=postgresql+asyncpg://xgzh:xgzh_dev_pass@localhost:5432/xgzh
DB_ECHO_SQL=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ====== SMS / OTP ======
SMS_ADAPTER=mock
# 当 SMS_ADAPTER=aliyun 时必填:
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_ID=
ALIYUN_SMS_INTL_TEMPLATE_ID=
OTP_TTL_SECONDS=300
OTP_RESEND_INTERVAL_SECONDS=60
OTP_VERIFY_MAX_ATTEMPTS=5

# ====== JWT ======
# 生产环境务必替换! 至少 32 字节, 建议: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ISSUER=xgzh-api
JWT_AUDIENCE=xgzh-mp
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=2592000

# ====== Free quota ======
FREE_AGENT_DAILY_LIMIT=5
