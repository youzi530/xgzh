# ====== Server ======
APP_NAME=xgzh-api
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ====== LLM Provider ======
# 推荐：硅基流动 (SiliconFlow) - 一站式接入 DeepSeek / GLM / Qwen / bge
# 注册: https://siliconflow.cn  (新用户送额度)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 或: DeepSeek 官方
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 或: 智谱 GLM
ZHIPU_API_KEY=

# 主力模型选择 (LiteLLM 格式)
# 硅基流动: openai/deepseek-ai/DeepSeek-V3
# DeepSeek 官方: deepseek/deepseek-chat
# 智谱: zhipu/glm-4-flash
LLM_PRIMARY_MODEL=openai/deepseek-ai/DeepSeek-V3
LLM_FALLBACK_MODEL=openai/THUDM/glm-4-9b-chat

# Embedding / Rerank 模型 (BE-S2-002)
# bge-m3 输出 1024 维, 与 0001_init 的 vector(1024) 列对齐
LLM_EMBEDDING_MODEL=openai/BAAI/bge-m3
LLM_EMBEDDING_DIM=1024
LLM_EMBEDDING_BATCH_SIZE=32
# bge-reranker-v2-m3 走硅基流动 /v1/rerank (cohere 兼容协议)
LLM_RERANK_MODEL=BAAI/bge-reranker-v2-m3

LLM_CHAT_DEFAULT_TEMPERATURE=0.3
LLM_REQUEST_TIMEOUT_SECONDS=60.0

# ====== Data Sources ======
# Tushare Pro Token (可选, AKShare 不需要)
# 注册: https://tushare.pro/register
TUSHARE_TOKEN=

# ====== Redis (可选, 缓存/限流) ======
REDIS_URL=redis://localhost:6379/0

# ====== Postgres ======
DATABASE_URL=postgresql+asyncpg://xgzh:xgzh_dev_pass@localhost:5432/xgzh
DB_ECHO_SQL=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ====== SMS / OTP ======
SMS_ADAPTER=mock
# 当 SMS_ADAPTER=aliyun 时必填:
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_ID=
ALIYUN_SMS_INTL_TEMPLATE_ID=
OTP_TTL_SECONDS=300
OTP_RESEND_INTERVAL_SECONDS=60
OTP_VERIFY_MAX_ATTEMPTS=5

# ====== JWT ======
# 生产环境务必替换! 至少 32 字节, 建议: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ISSUER=xgzh-api
JWT_AUDIENCE=xgzh-mp
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=2592000

# ====== WeChat Mini Program (BE-005) ======
# 微信公众平台 / 小程序 → 开发管理 → 开发设置 拿到 AppID / AppSecret
# 留空则 /auth/login/wechat-mp 返回 503 (服务未启用)
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=
# 一般无需修改; 测试时可指向本地 mock 地址
WECHAT_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
WECHAT_CODE2SESSION_TIMEOUT_SECONDS=5.0

# ====== Scheduler / IPO Ingest (BE-007) ======
# 后台 APScheduler 总开关. 测试 / 一次性脚本场景关掉.
SCHEDULER_ENABLED=true
# 启动后多少秒触发一次 A 股 IPO 抓取. 0 = 关闭立即跑, 仅依赖 cron.
IPO_INGEST_INITIAL_DELAY_SECONDS=5
# 每日定时抓取的小时 (Asia/Shanghai), 多个用逗号分隔.
IPO_INGEST_CRON_HOURS=8,20
# 每次抓 A 股 IPO 的最大行数 (CNINFO 接口 ~500 行覆盖近 2 年).
IPO_INGEST_A_LIMIT=200
IPO_INGEST_TIMEZONE=Asia/Shanghai

# ====== HK IPO Ingest (BE-S2-000, hkexnews) ======
# hkexnews 域名根. 申请人列表页: ${HKEX_BASE_URL}/app/listing/applicants/applicants_c.htm
HKEX_BASE_URL=https://www1.hkexnews.hk
# HK 抓 cron (Asia/Hong_Kong); 早盘前 + 收盘后二刀流
IPO_INGEST_HK_CRON_HOURS=9,17
IPO_INGEST_HK_INITIAL_DELAY_SECONDS=10
IPO_INGEST_HK_TIMEZONE=Asia/Hong_Kong
IPO_INGEST_HK_LIMIT=100
# hkexnews 反爬阈值实测约 2 req/s; 默认 2 并发已经友好
IPO_INGEST_HK_REQUEST_CONCURRENCY=2
IPO_INGEST_HK_REQUEST_TIMEOUT_SECONDS=10.0

# ====== Prospectus PDF Ingest (BE-S2-004, RAG 流水线) ======
# 单份 PDF 上限 (MB); 超尺寸直接拒收防 OOM
PDF_MAX_SIZE_MB=50
# 下载招股书 PDF HTTP 超时 (s); 几十 MB 文件远比列表慢
PDF_REQUEST_TIMEOUT_SECONDS=60.0
# 切分粒度 (token / chunk); 500 ≈ 中文 750 字 / 英文 2000 字
RAG_CHUNK_SIZE_TOKENS=500
# 相邻 chunk overlap (token); 10% 是 LangChain 事实默认
RAG_CHUNK_OVERLAP_TOKENS=50

# ====== Hybrid Search (BE-S2-005, vector + BM25 + RRF + rerank) ======
# 向量召回先取 N 条; HNSW + 1024-d 取 50 在毫秒级
RAG_VECTOR_TOP_K=50
# BM25 召回先取 N 条; PG GIN + ts_rank_cd 取 50 在毫秒级
RAG_BM25_TOP_K=50
# RRF 衰减常数 (Cormack 2009 默认 60)
RAG_RRF_K=60
# 送 reranker 的候选池大小 (性价比拐点 ~20)
RAG_RERANK_POOL_SIZE=20
# 最终返回 chunk 数 (spec/04 P0 KPI 对齐 top5)
RAG_FINAL_TOP_K=5
# 是否走 reranker (CI 默认关; 生产开; 关时 fallback RRF 排序)
RAG_USE_RERANK=true

# ====== Free quota ======
FREE_AGENT_DAILY_LIMIT=5
