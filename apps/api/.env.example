# ====== Server ======
APP_NAME=xgzh-api
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ====== LLM Provider ======
# 推荐：硅基流动 (SiliconFlow) - 一站式接入 DeepSeek / GLM / Qwen / bge
# 注册: https://siliconflow.cn  (新用户送额度)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 或: DeepSeek 官方
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 或: 智谱 GLM
ZHIPU_API_KEY=

# 主力模型选择 (LiteLLM 格式)
# 硅基流动: openai/deepseek-ai/DeepSeek-V3
# DeepSeek 官方: deepseek/deepseek-chat
# 智谱: zhipu/glm-4-flash
LLM_PRIMARY_MODEL=openai/deepseek-ai/DeepSeek-V3
LLM_FALLBACK_MODEL=openai/THUDM/glm-4-9b-chat

# Embedding / Rerank 模型 (BE-S2-002)
# bge-m3 输出 1024 维, 与 0001_init 的 vector(1024) 列对齐
LLM_EMBEDDING_MODEL=openai/BAAI/bge-m3
LLM_EMBEDDING_DIM=1024
LLM_EMBEDDING_BATCH_SIZE=32
# bge-reranker-v2-m3 走硅基流动 /v1/rerank (cohere 兼容协议)
LLM_RERANK_MODEL=BAAI/bge-reranker-v2-m3

LLM_CHAT_DEFAULT_TEMPERATURE=0.3
LLM_REQUEST_TIMEOUT_SECONDS=60.0

# ====== Data Sources ======
# Tushare Pro Token (可选, AKShare 不需要)
# 注册: https://tushare.pro/register
TUSHARE_TOKEN=

# ====== Redis (可选, 缓存/限流) ======
REDIS_URL=redis://localhost:6379/0

# ====== Postgres ======
DATABASE_URL=postgresql+asyncpg://xgzh:xgzh_dev_pass@localhost:5432/xgzh
DB_ECHO_SQL=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ====== SMS / OTP ======
SMS_ADAPTER=mock
# 当 SMS_ADAPTER=aliyun 时必填:
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_ID=
ALIYUN_SMS_INTL_TEMPLATE_ID=
OTP_TTL_SECONDS=300
OTP_RESEND_INTERVAL_SECONDS=60
OTP_VERIFY_MAX_ATTEMPTS=5

# ====== JWT ======
# 生产环境务必替换! 至少 32 字节, 建议: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ISSUER=xgzh-api
JWT_AUDIENCE=xgzh-mp
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=2592000

# ====== WeChat Mini Program (BE-005) ======
# 微信公众平台 / 小程序 → 开发管理 → 开发设置 拿到 AppID / AppSecret
# 留空则 /auth/login/wechat-mp 返回 503 (服务未启用)
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=
# 一般无需修改; 测试时可指向本地 mock 地址
WECHAT_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
WECHAT_CODE2SESSION_TIMEOUT_SECONDS=5.0

# ====== Scheduler / IPO Ingest (BE-007) ======
# 后台 APScheduler 总开关. 测试 / 一次性脚本场景关掉.
SCHEDULER_ENABLED=true
# 启动后多少秒触发一次 A 股 IPO 抓取. 0 = 关闭立即跑, 仅依赖 cron.
IPO_INGEST_INITIAL_DELAY_SECONDS=5
# 每日定时抓取的小时 (Asia/Shanghai), 多个用逗号分隔.
IPO_INGEST_CRON_HOURS=8,20
# 每次抓 A 股 IPO 的最大行数 (CNINFO 接口 ~500 行覆盖近 2 年).
IPO_INGEST_A_LIMIT=200
IPO_INGEST_TIMEZONE=Asia/Shanghai

# ====== HK IPO Ingest (BE-S2-000, hkexnews) ======
# hkexnews 域名根. 申请人列表页: ${HKEX_BASE_URL}/app/listing/applicants/applicants_c.htm
HKEX_BASE_URL=https://www1.hkexnews.hk
# HK 抓 cron (Asia/Hong_Kong); 早盘前 + 收盘后二刀流
IPO_INGEST_HK_CRON_HOURS=9,17
IPO_INGEST_HK_INITIAL_DELAY_SECONDS=10
IPO_INGEST_HK_TIMEZONE=Asia/Hong_Kong
IPO_INGEST_HK_LIMIT=100
# hkexnews 反爬阈值实测约 2 req/s; 默认 2 并发已经友好
IPO_INGEST_HK_REQUEST_CONCURRENCY=2
IPO_INGEST_HK_REQUEST_TIMEOUT_SECONDS=10.0

# ====== Prospectus PDF Ingest (BE-S2-004, RAG 流水线) ======
# 单份 PDF 上限 (MB); 超尺寸直接拒收防 OOM
PDF_MAX_SIZE_MB=50
# 下载招股书 PDF HTTP 超时 (s); 几十 MB 文件远比列表慢
PDF_REQUEST_TIMEOUT_SECONDS=60.0
# 切分粒度 (token / chunk); 500 ≈ 中文 750 字 / 英文 2000 字
RAG_CHUNK_SIZE_TOKENS=500
# 相邻 chunk overlap (token); 10% 是 LangChain 事实默认
RAG_CHUNK_OVERLAP_TOKENS=50

# ====== Hybrid Search (BE-S2-005, vector + BM25 + RRF + rerank) ======
# 向量召回先取 N 条; HNSW + 1024-d 取 50 在毫秒级
RAG_VECTOR_TOP_K=50
# BM25 召回先取 N 条; PG GIN + ts_rank_cd 取 50 在毫秒级
RAG_BM25_TOP_K=50
# RRF 衰减常数 (Cormack 2009 默认 60)
RAG_RRF_K=60
# 送 reranker 的候选池大小 (性价比拐点 ~20)
RAG_RERANK_POOL_SIZE=20
# 最终返回 chunk 数 (spec/04 P0 KPI 对齐 top5)
RAG_FINAL_TOP_K=5
# 是否走 reranker (CI 默认关; 生产开; 关时 fallback RRF 排序)
RAG_USE_RERANK=true

# ====== Article Ingest (BE-S3-002, 多源文章入库框架) ======
# 启动后多少秒触发一次文章 ingest. 0 = 关闭立即跑, 仅依赖 cron.
# 默认比 IPO ingest 晚 15s (IPO ingest 5/10s), 让 IPO 表先有数据再跑文章 (依赖关键词反查).
ARTICLE_INGEST_INITIAL_DELAY_SECONDS=15
# Cron 分钟表达式 (Asia/Shanghai), APScheduler CronTrigger.minute 兼容 (0-59)
# 默认 0 = 每小时第 0 分跑一次. 也可写 ``0,30`` (每 30 分一次) / ``*/15`` (每 15 分一次)
ARTICLE_INGEST_CRON_EXPR=0
# 各 source 并发抓取上限 (asyncio.Semaphore). 雪球反爬阈值实测约 5 req/s, 默认 3 友好.
ARTICLE_INGEST_REQUEST_CONCURRENCY=3
# 单次 HTTP 请求超时. 雪球 / 智通 RSS 上游 P99 < 2s, 留 5x buffer
ARTICLE_INGEST_REQUEST_TIMEOUT_SECONDS=10.0
# 雪球域名根. status 搜索: ``/query/v1/symbol/search/status.json``
XUEQIU_BASE_URL=https://xueqiu.com
# 雪球单次关键词搜索拉取条数 (上游 count 参数)
ARTICLE_INGEST_XUEQIU_COUNT_PER_QUERY=20
# 单次 ingest 最多跑多少个关键词查询雪球 (防活跃 IPO 100+ 时打爆雪球 API)
ARTICLE_INGEST_XUEQIU_MAX_QUERIES=20
# 智通财经 RSS feed URL. 留空则跳过该 source
ZHITONG_RSS_URL=https://www.zhitongcaijing.com/rss/news.xml

# ====== Article Dedup (BE-S3-003, simhash 64 bit + 同主题折叠) ======
# 海明距离 ≤ 此值视为同主题. 3 = 99% 同主题召回率; 5 = 70% 召回率噪音 +5%
ARTICLE_DEDUP_SIMHASH_THRESHOLD=3
# 候选池查询窗口 (近 N 小时). 复刊 / 转发几乎都在 24h 内, 跨天不视为同主题
ARTICLE_DEDUP_WINDOW_HOURS=24
# 全局重 cluster job cron 小时表达式 (Asia/Shanghai). ``*/4`` = 每 4h 跑一次
# 兜底处理: 入库时 simhash 失败 / 跨批兄弟文乱序入库 / 测试 / 历史回填
ARTICLE_DEDUP_RECLUSTER_CRON_HOURS=*/4
# 启动后多少秒触发一次 recluster. 0 = 关闭立即跑, 仅依赖 cron
ARTICLE_DEDUP_RECLUSTER_INITIAL_DELAY_SECONDS=30

# ====== BE-S3-004 文章情感打标 ======
# 默认 zhipu/glm-4-flash (免费); 可切 deepseek/deepseek-chat / openai/deepseek-ai/DeepSeek-V3
ARTICLE_SENTIMENT_MODEL=zhipu/glm-4-flash
# 单次 LLM 调用文章数. 10 篇适配 GLM-4-Flash 8K 上限; 调大省 token 但失败面大
ARTICLE_SENTIMENT_BATCH_SIZE=10
# 兜底 job cron 分钟表达式. ``*/30`` = 每 30 min 兜底一次
ARTICLE_SENTIMENT_CRON_MINUTES=*/30
# 启动后多少秒触发一次首批打标. 默认 45s (晚于 ingest 15s + dedup 30s)
ARTICLE_SENTIMENT_INITIAL_DELAY_SECONDS=45
# 兜底扫 sentiment IS NULL 的回看窗口 (小时); 跨此值后视为存量历史
ARTICLE_SENTIMENT_BACKFILL_WINDOW_HOURS=24
# 兜底单次最多打标数, 防雪崩 + 防 LLM rate limit
ARTICLE_SENTIMENT_BACKFILL_LIMIT=200

# ====== BE-S3-005 文章 TL;DR ======
# LLM model slug (默认 GLM-4-Flash 免费); 重要场景可切 deepseek-chat 或 DeepSeek-V3
ARTICLE_TLDR_MODEL=zhipu/glm-4-flash
# 候选池回看窗口 (天). 7 天 = 新鲜度 + 池足够大
ARTICLE_TLDR_WINDOW_DAYS=7
# 候选池大小上限 (Top N by hot_score). 30 篇 ~ GLM-4-Flash 8K token 上限
ARTICLE_TLDR_POOL_SIZE=30
# Redis 缓存 TTL (秒). 1800 = 30 min, 平衡新鲜度 vs LLM cost
ARTICLE_TLDR_CACHE_TTL_SECONDS=1800

# ====== Free quota ======
FREE_AGENT_DAILY_LIMIT=5

# ====== OPS-S4-001 灰度 + 监控 ======
# Admin API token (X-Admin-Token header). 留空 = /api/v1/admin/* 全部 503 admin_disabled.
# 生产必须设置 32+ 字节随机串. dev 想跑 admin endpoint 时显式设置即可.
# 例: OPS_ADMIN_TOKEN=dev-admin-token-please-change-in-prod-32bytes
OPS_ADMIN_TOKEN=

# bootstrap 用的初始 flag 表 (JSON map). 服务启动时若 Redis 没数据回填一次;
# 已存在的不覆盖 (admin 改过的不会被回滚). 留空 = 不回填.
# 例: FEATURE_FLAGS_DEFAULT={"history_tab":{"enabled":true,"rollout_pct":5}}
FEATURE_FLAGS_DEFAULT=

# FE 端 feature flag 缓存 TTL (秒). 灰度旋钮变化在此时间内全机器对齐.
FEATURE_FLAGS_CACHE_TTL_SECONDS=60

# 错误率告警阈值 (% 0-100). 5xx + unhandled exception 占比超过此值触发钉钉告警.
ERROR_ALERT_THRESHOLD_PCT=1.0
# 错误率统计的滑动窗口 (秒). 与告警频率一致, 默认 1 min.
ERROR_ALERT_WINDOW_SECONDS=60
# 钉钉机器人 webhook URL. 留空 = 仅 logger.error, 不真发. dev 默认空.
ALERT_DINGTALK_WEBHOOK=

# ====== BE-S3-009 VIP 订阅 / 试用 / 过期 scheduler ======
# 新注册用户自动获赠的 VIP 试用天数. spec/06 §2.3 默认 7 天; 改为 0 关闭试用.
VIP_TRIAL_DAYS=7
# VIP 过期 scheduler 启动后延迟秒数. 0 = 关闭立即跑仅依赖 cron.
VIP_MEMBERSHIP_EXPIRE_INITIAL_DELAY_SECONDS=20
# 过期扫描 cron 小时 (APScheduler CronTrigger.hour 兼容). 默认 ``*`` 每小时一次
VIP_MEMBERSHIP_EXPIRE_CRON_HOURS=*
# 整点偏移分钟, 默认 15 错开整点 ingest 高峰
VIP_MEMBERSHIP_EXPIRE_CRON_MINUTE=15

# ====== BE-S3-010 微信支付 v3 (JSAPI 小程序内支付) ======
# Dev 模拟模式. true = 走 StubWechatPayClient (无需真商户号 / 私钥); 生产强制 false.
WECHATPAY_DEV_MODE=true
# 微信支付商户号 (mchid); 微信支付商户平台 → 账户中心 → 商户信息. dev_mode=true 时可留空.
WECHATPAY_MCH_ID=
# APIv3 密钥 (32 位字符串), AES-GCM 解密回调 resource 用. 商户平台 → API 安全 → 设置 APIv3 密钥
WECHATPAY_APIV3_KEY=
# 商户 API 证书序列号; 商户平台 → API 安全 → 应用 API 证书 → 序列号
WECHATPAY_CERT_SERIAL_NO=
# 商户 API 证书私钥 apiclient_key.pem 绝对路径. 私钥严禁入 git, 部署时挂载.
WECHATPAY_PRIVATE_KEY_PATH=
# 微信支付回调 URL (公网可访问, HTTPS). 例: https://api.xgzh.com/api/v1/pay/wechat/notify
WECHATPAY_NOTIFY_URL=
# 微信支付绑定的 AppID (与 WECHAT_MP_APP_ID 通常一致). dev_mode=true 时可留空
WECHATPAY_APP_ID=
# 同用户 + 同 plan 在 N 秒内重复下单 → 复用旧 pending 订单 (防双击). 默认 300s = 5 min
WECHATPAY_ORDER_IDEMPOTENCY_SECONDS=300
