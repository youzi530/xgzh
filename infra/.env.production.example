# bug-fix-2305 / spec/25 — 生产 .env 模板
#
# 用法:
#   cp .env.production.example .env
#   vi .env   # 填入真实值, 不要 commit!
#
# ⚠️ 安全:
#   - 这个 example 文件进 git (供其他人参考字段)
#   - 实际 .env  绝对不进 git, 仅在服务器 /opt/xgzh/.env 维护
#   - 每个 *_PASSWORD / *_SECRET / *_KEY / *_TOKEN 都要换成真实强值

# ─── 镜像仓库 (阿里云 ACR) ──────────────────────────────────────
# 与 GitHub Secrets 同步; .env 这里是给 docker compose 拉镜像用
ACR_REGISTRY=registry.cn-beijing.aliyuncs.com
ACR_NAMESPACE=xgzh
ACR_REPOSITORY=api
# IMAGE_TAG 由 GitHub Actions deploy.yml 写入, 启动时是 git sha (前 7 位).
# 首次手动部署可填 latest
IMAGE_TAG=latest

# ─── PostgreSQL ─────────────────────────────────────────────
# ⚠️ 强密码! 至少 16 字符, 含大小写 + 数字 + 符号
# 生成: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ─── 应用鉴权 ──────────────────────────────────────────────
# JWT 签名密钥, 64 字符随机
# 生成: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX_STRING

# ─── CORS ────────────────────────────────────────────────
# 允许跨域来源, 逗号分隔. 生产收紧只放真实前端域名
# 例: https://xgzh.example.com,https://h5.xgzh.example.com
CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# ─── LLM API keys (按需配, 没配的功能 fallback 不报错) ────────
# SiliconFlow (embedding 用)
SILICONFLOW_API_KEY=

# DeepSeek (主对话 LLM 推荐)
DEEPSEEK_API_KEY=

# 智谱 AI (GLM 系列, 备选 LLM)
ZHIPU_API_KEY=

# ─── 长桥 OpenAPI (Sprint 7.3 token-gated KOL 数据源) ────────
# 没配则 KOL 数据源仅 Sogou 单源; 配上后多 2 个数据源 (新闻 + 社区)
# 申请: https://open.longbridgeapp.com/zh-CN
LONGBRIDGE_API_TOKEN=
